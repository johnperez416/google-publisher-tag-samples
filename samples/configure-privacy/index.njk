{% extends '../../src/_includes/sample-layout.njk'%}
{% block html %}
  <div id="banner-ad" style="width: 728px; height: 90px"></div>
  <div>
    <button id="npaButton">Non-personalized Ads</button>
    <button id="rdpButton">Restricted Data Processing</button>
    <button id="tfatButton" data-value="UNSPECIFIED">Age Treatment</button>
    <button id="tfuaButton">Under Age of Consent</button>
    <button id="tfcdButton">Child Directed Treatment</button>
  </div>
{% endblock %}
{% block styles %}
  button::after {
    content: 'OFF';
    color: red;
    font-weight: bold;
  }

  button[data-enabled='true']::after {
    content: 'ON';
    color: green;
    font-weight: bold;
  }

  #tfatButton::after {
    content: attr(data-value);
    font-weight: bold;
  }


  #tfatButton[data-value='UNSPECIFIED']::after {
    color: red;
  }

  #tfatButton[data-value='CHILD']::after,
  #tfatButton[data-value='TEEN']::after {
    color: green;
  }
{% endblock %}